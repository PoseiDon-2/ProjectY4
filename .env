# --- Application Setting ---
APP_NAME="DonateSwipe"
APP_ENV=production
# ใช้ Key เดิมของคุณ เพื่อให้ข้อมูลที่เข้ารหัสไว้ (ถ้ามี) ยังอ่านได้
APP_KEY=base64:+tYVUeeRINruQfNb6/SkkgiIUpH5W2oQjb7dldti47c=
APP_DEBUG=false
APP_URL=http://10.198.200.70

# --- Locale ---
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
AUTH_GUARD=api
APP_MAINTENANCE_DRIVER=file

# --- Server Performance ---
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# --- Logging ---
# แนะนำให้ใช้ daily เพื่อไม่ให้ไฟล์ log ใหญ่เกินไปจนเต็มเครื่อง
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# --- Database Connection (สำคัญ!) ---
DB_CONNECTION=mysql
# ⚠️ ต้องใช้ชื่อ Service ว่า "database" (ตาม docker-compose)
DB_HOST=database
DB_PORT=3306
# ⚠️ ชื่อฐานข้อมูลต้องตรงกับ MYSQL_DATABASE ใน docker-compose.yml (myapp_db หรือ donation_db เลือกเอาสักอันครับ)
DB_DATABASE=donation_db
DB_USERNAME=root
# ⚠️ รหัสผ่านต้องตรงกับ MYSQL_ROOT_PASSWORD ใน docker-compose.yml
DB_PASSWORD=rootpassword

# --- Session & Sanctum (แก้ให้ตรงกับ IP Server) ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# ใส่ IP Server เพื่อให้ Login ได้
SANCTUM_STATEFUL_DOMAINS=10.198.200.70
SESSION_DOMAIN=10.198.200.70

# --- Queue & Filesystem ---
BROADCAST_CONNECTION=log
# เปลี่ยนเป็น public เพื่อให้เก็บรูปแล้วเปิดดูผ่าน URL ได้
FILESYSTEM_DISK=public
# เปลี่ยนเป็น sync เพื่อให้ทำงานทันที (ไม่ต้องตั้ง worker แยกให้ยุ่งยาก)
QUEUE_CONNECTION=sync

# --- Cache ---
CACHE_DRIVER=file

# --- Redis (ใน Docker คุณไม่มี Redis ผมปิดให้ก่อนจะได้ไม่ Error) ---
# MEMCACHED_HOST=127.0.0.1
# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# ...

# --- Mail (Server Offline ต้องใช้ log เท่านั้น) ---
# ถ้าใช้ smtp เว็บจะหมุนติ้วแล้ว time out เพราะออกเน็ตไปหา Gmail ไม่ได้
MAIL_MAILER=log
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=Suriya.b@kkumail.com
MAIL_PASSWORD=kwawscmgqdfwvtwl
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=Suriya.b@kkumail.com
MAIL_FROM_NAME="DonateSwipe"

# --- AWS (Offline ใช้ไม่ได้ ปล่อยว่างไว้) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"